unit untPromocao;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.StdCtrls;

type
  TfrmPromocao = class(TForm)
    lblNome: TLabel;
    lblSalario: TLabel;
    lblTempo: TLabel;
    lblReclama: TLabel;
    btnVerify: TButton;
    edtNome: TEdit;
    edtTempo: TEdit;
    edtSalario: TEdit;
    edtReclama: TEdit;
    procedure btnVerifyClick(Sender: TObject);
  private
    { Private declarations }
  public
    { Public declarations }
  end;

var
  frmPromocao: TfrmPromocao;

implementation

{$R *.dfm}

procedure TfrmPromocao.btnVerifyClick(Sender: TObject);
var
  nome: string;
  salario: real;
  tempServ: integer;
  reclamacao: boolean;

begin

  nome := edtNome.Text;
  salario := strtofloat(edtSalario.Text);
  tempServ := strtoint(edtTempo.Text);

  // Verificaçăo de reclamaçăo
  if edtReclama.text = 'Sim' then
    begin
      reclamacao := true;
    end
  else if edtReclama.text = 'Năo' then
    begin
       reclamacao := false;
    end
  Else
    begin
      reclamacao := true
    end;


    // Verificaçăo de edit's vazias
    if nome = '' then
      begin
        ShowMessage('Nome invalido ou vazio.');
      end

    else if salario = null then
      begin
        ShowMessage('Salario invalido ou vazio.');
      end

    else if tempServ < 10 then

      begin
         ShowMessage('Tempo de serviço invalido ou vazio');
      end

    else
      begin
        ShowMessage('Dados validos!')
      end;


    if salario > 1000 then
      begin
        if tempServ >= 10 then
          begin
            if reclamacao = false then
              begin
                ShowMessage('Olá ' + nome + ', vocę foi promotivo!')
              end;
          end;

      end
    else
      begin
        ShowMessage('Vocę năo foi promovido')
      end;
  end;
end.
